{
   // Use IntelliSense to learn about possible attributes.
   // Hover to view descriptions of existing attributes.
   // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
   "version": "0.2.0",
   "configurations": [
      {
         "type": "node-terminal",
         "request": "launch",
         "command": "cd section3-basics/05-node-module-system && npm start",
         "name": "node-terminal-npm-start"
      },
      {
         "type": "node",
         "request": "launch",
         "name": "Launch via npm start",
         "runtimeExecutable": "npm",
         "runtimeArgs": ["start"],
         "cwd": "${workspaceFolder}/section3-basics/05-node-module-system",
         "console": "integratedTerminal"
      },
      {
         "type": "node",
         "request": "launch",
         "name": "05-node-module-system-nodemon",
         "skipFiles": [
            "<node_internals>/**"
         ],
         "program": "${workspaceFolder}/section3-basics/05-node-module-system/app.js",
         "console": "integratedTerminal",
         "restart": true,
         "runtimeExecutable": "nodemon"
         // "Make sure to install nodemon globally using 'npm install -g nodemon' before using this configuration."
         // Also, nodemon needs to be stopped manually in the terminal after debugging, as it will keep running to watch for file changes.
      }
   ]
}